{
	"name": "better-drizzle",
	"version": "0.0.0",
	"description": "Minimal, type-safe repository helpers for Drizzle ORM.",
	"license": "Apache-2.0",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"LICENSE",
		"dist",
		"README.md"
	],
	"keywords": [
		"drizzle",
		"drizzle-orm",
		"orm",
		"typescript",
		"repository",
		"sqlite",
		"postgres",
		"mysql"
	],
	"homepage": "https://github.com/almeidazs/better-drizzle#readme",
	"bugs": {
		"url": "https://github.com/almeidazs/better-drizzle/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidazs/better-drizzle.git",
		"directory": "packages/core"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "bun run ../../scripts/build.ts core"
	},
	"sideEffects": false,
	"type": "module",
	"peerDependencies": {
		"drizzle-orm": "^0.45.2",
		"typescript": "^5"
	}
}
