{
	"name": "@better-drizzle/soft-delete",
	"version": "0.1.0",
	"description": "Soft delete plugin for better-drizzle.",
	"license": "Apache-2.0",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"LICENSE",
		"dist",
		"README.md"
	],
	"keywords": [
		"better-drizzle",
		"drizzle",
		"drizzle-orm",
		"plugin",
		"soft-delete"
	],
	"homepage": "https://better-drizzle.vercel.app/",
	"bugs": {
		"url": "https://github.com/almeidazs/better-drizzle/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidazs/better-drizzle.git",
		"directory": "packages/soft-delete"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "bun run ../../scripts/build.ts soft-delete"
	},
	"sideEffects": false,
	"type": "module",
	"peerDependencies": {
		"better-drizzle": "^0.1.0",
		"drizzle-orm": "^0.30.0",
		"typescript": "^5"
	},
	"devDependencies": {
		"better-drizzle": "workspace:*"
	}
}
