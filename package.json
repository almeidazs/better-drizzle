{
	"name": "better-drizzle-workspace",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"check": "bun run check:types && bun run check:lint && bun run test && bun run pack:core && bun run pack:timestamps && bun run pack:soft-delete",
		"check:lint": "bunx @biomejs/biome check packages/core packages/timestamps packages/soft-delete benchmark .github",
		"check:types": "bunx tsc --noEmit",
		"bench": "bun run benchmark/time.ts",
		"bench:all": "bun run benchmark/time.ts && bun run benchmark/memory.ts",
		"bench:memory": "bun run benchmark/memory.ts",
		"pack:core": "cd packages/core && npm pack --dry-run",
		"pack:timestamps": "cd packages/timestamps && npm pack --dry-run",
		"pack:soft-delete": "cd packages/soft-delete && npm pack --dry-run",
		"test": "bun test packages/core/tests packages/timestamps/tests packages/soft-delete/tests"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@commitlint/config-conventional": "^21.1.0",
		"@types/bun": "latest",
		"commitlint": "^21.1.0",
		"mitata": "^1.0.34"
	},
	"peerDependencies": {
		"drizzle-orm": "^0.45.2",
		"typescript": "^5"
	}
}
