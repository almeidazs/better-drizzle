{
	"name": "better-drizzle-workspace",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"check": "bun run check:types && bun run check:lint && bun run pack:core",
		"check:lint": "bunx @biomejs/biome check packages/core/src benchmark .github",
		"check:types": "bunx tsc --noEmit",
		"bench": "bun run benchmark/time.ts",
		"bench:all": "bun run benchmark/time.ts && bun run benchmark/memory.ts",
		"bench:memory": "bun run benchmark/memory.ts",
		"pack:core": "cd packages/core && npm pack --dry-run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@commitlint/config-conventional": "^21.0.2",
		"@types/bun": "latest",
		"commitlint": "^21.0.2",
		"mitata": "^1.0.34"
	},
	"peerDependencies": {
		"drizzle-orm": "^0.45.2",
		"typescript": "^5"
	}
}
